{
  "extends": "./tsconfig/tsconfig.all.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "build",
    "node_modules",
    "src/bench_*.ts"
  ]
}
